# HTTP (opcional; padrão 3333)
PORT=

# Postgres: uma única URL para runtime e drizzle-kit (generate/migrate).
# Formato: postgresql://USUARIO:SENHA@host:5432/nome_do_banco
# Se a senha tiver caracteres especiais (@, :, #, etc.), use encoding percentual na URL.
DATABASE_URL=

CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ACCESS_KEY_ID=
CLOUDFLARE_SECRET_ACCESS_KEY=
CLOUDFLARE_PUBLIC_URL=
CLOUDFLARE_BUCKET=
